@page "/produtores"
@using ControleDeVinil.Shared.Modelos.Modelos

@inject HttpClient httpClient
@inject IJSRuntime JSRuntime

<h1>Lista de Produtores</h1>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var produtor in produtores)
        {
            <tr>
                <td>@produtor.Id</td>
                <td>@produtor.Nome</td>
                <td>@produtor.Email</td>
                <td>
                    <button class="btn btn-sm btn-primary" @onclick="() => EditarProdutor(produtor.Id)">Editar</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmarExclusao(produtor.Id)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<button class="btn btn-success" @onclick="AdicionarProdutor">Adicionar Produtor</button>

@if (mostrarModal)
{
    <div class="modal fade show" tabindex="-1" style="display: block;">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitulo</h5>
                    <button type="button" class="close" @onclick="FecharModal">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="form-group">
                            <label for="nome">Nome</label>
                            <input type="text" class="form-control" id="nome" @bind="produtor.Nome">
                        </div>
                        <div class="form-group">
                            <label for="email">E-mail</label>
                            <input type="email" class="form-control" id="email" @bind="produtor.Email">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="SalvarProdutor">Salvar</button>
                    <button type="button" class="btn btn-secondary" @onclick="FecharModal">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<Produtor> produtores = new List<Produtor>();
    Produtor produtor = new Produtor();
    bool mostrarModal = false;
    string modalTitulo = "";

    protected override async Task OnInitializedAsync()
    {
        await CarregarProdutores();
    }

    private async Task CarregarProdutores()
    {
        try
        {
            produtores = await httpClient.GetFromJsonAsync<List<Produtor>>("api/produtor");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar produtores: {ex.Message}");
        }
    }

    private void AdicionarProdutor()
    {
        produtor = new Produtor();
        modalTitulo = "Adicionar Produtor";
        mostrarModal = true;
    }

    private async Task SalvarProdutor()
    {
        try
        {
            if (produtor.Id == 0)
            {
                var response = await httpClient.PostAsJsonAsync("api/produtor", produtor);
                if (response.IsSuccessStatusCode)
                {
                    // Adiciona o novo produtor à lista
                    produtores.Add(produtor);

                    // Limpa o objeto produtor para o próximo uso
                    produtor = new Produtor();

                    // Fecha o modal e atualiza a interface
                    FecharModal();
                }
            }
            else
            {
                var response = await httpClient.PutAsJsonAsync($"api/produtor/{produtor.Id}", produtor);
                if (response.IsSuccessStatusCode)
                {
                    await CarregarProdutores();
                    FecharModal();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao salvar produtor: {ex.Message}");
        }
    }

    private void EditarProdutor(int id)
    {
        produtor = produtores.FirstOrDefault(p => p.Id == id);
        if (produtor != null)
        {
            modalTitulo = "Editar Produtor";
            mostrarModal = true;
        }
    }

    private async Task ConfirmarExclusao(int id)
    {
        var confirmar = await JSRuntime.InvokeAsync<bool>("confirm", "Deseja realmente excluir este produtor?");
        if (confirmar)
        {
            var response = await httpClient.DeleteAsync($"api/produtor/{id}");
            if (response.IsSuccessStatusCode)
            {
                await CarregarProdutores();
            }
        }
    }

    private void FecharModal()
    {
        mostrarModal = false;
    }
}
